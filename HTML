<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hardik Parmar | Dav Launch Studio - Premium Web & App Development</title>
    <meta name="description" content="Affordable, high-quality web and app development for startups and small businesses. Transform your ideas into digital reality with Hardik Parmar.">
    <meta name="keywords" content="Web Development, App Development, UI/UX Design, Freelance Developer, Dav Launch Studio, Hardik Parmar">
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@700;800&display=swap" rel="stylesheet">
    
    <!-- Icons & Animations -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.css">
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <link rel="stylesheet" href="css/style.css">
</head>
<body>

    <!-- Sticky Navigation -->
    <nav class="navbar">
        <div class="container">
            <a href="#" class="logo">DAV<span>LAUNCH</span></a>
            <ul class="nav-links">
                <li><a href="#services">Services</a></li>
                <li><a href="#work">Work</a></li>
                <li><a href="#pricing">Pricing</a></li>
                <li><a href="#contact" class="btn-primary">Hire Me</a></li>
            </ul>
            <div class="menu-toggle"><i data-lucide="menu"></i></div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero">
        <div class="container">
            <div class="hero-content" data-aos="fade-up">
                <span class="badge">Available for new projects</span>
                <h1>High-Performance Digital Products for <span>Ambitious Startups.</span></h1>
                <p>Stop losing leads to outdated design. I build fast, conversion-optimized websites and apps that turn visitors into loyal customers.</p>
                <div class="hero-btns">
                    <a href="#work" class="btn-primary">View My Work</a>
                    <a href="#contact" class="btn-secondary">Start a Project</a>
                </div>
                <div class="hero-trust">
                    <p>Trusted by clients globally</p>
                    <div class="trust-icons">
                        <i data-lucide="zap"></i> Fast Delivery 
                        <i data-lucide="shield-check"></i> Secure Code
                        <i data-lucide="smartphone"></i> Mobile First
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- About Section -->
    <section class="about" id="about">
        <div class="container grid">
            <div class="about-text" data-aos="fade-right">
                <h2>I don’t just write code. I build <span>business assets.</span></h2>
                <p>Most developers focus on features. I focus on your ROI. Whether you're a startup looking for an MVP or a small business scaling online, I bridge the gap between complex technology and business goals.</p>
                <div class="stats">
                    <div class="stat-item"><h3>20+</h3><p>Projects</p></div>
                    <div class="stat-item"><h3>99%</h3><p>Success Rate</p></div>
                </div>
            </div>
            <div class="about-card glass" data-aos="fade-left">
                <i data-lucide="code-2" class="icon-lg"></i>
                <h3>Hardik Parmar</h3>
                <p>Lead Developer & Designer at Dav Launch Studio</p>
            </div>
        </div>
    </section>

    <!-- Services -->
    <section class="services" id="services">
        <div class="container">
            <h2 class="section-title">Solutions I Provide</h2>
            <div class="grid cards">
                <div class="card glass" data-aos="zoom-in">
                    <i data-lucide="layout"></i>
                    <h3>Web Development</h3>
                    <p>SEO-friendly, blazing-fast websites using React, Next.js, or WordPress.</p>
                    <ul>
                        <li><i data-lucide="check"></i> Custom Dashboards</li>
                        <li><i data-lucide="check"></i> E-commerce Solutions</li>
                    </ul>
                </div>
                <div class="card glass" data-aos="zoom-in" data-aos-delay="100">
                    <i data-lucide="smartphone"></i>
                    <h3>App Development</h3>
                    <p>Native-feel cross-platform mobile apps that users love to engage with.</p>
                    <ul>
                        <li><i data-lucide="check"></i> iOS & Android</li>
                        <li><i data-lucide="check"></i> API Integration</li>
                    </ul>
                </div>
                <div class="card glass" data-aos="zoom-in" data-aos-delay="200">
                    <i data-lucide="palette"></i>
                    <h3>UI/UX Design</h3>
                    <p>User-centric designs that reduce bounce rates and increase conversions.</p>
                    <ul>
                        <li><i data-lucide="check"></i> Interactive Prototypes</li>
                        <li><i data-lucide="check"></i> Branding Kits</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- Portfolio -->
    <section class="portfolio" id="work">
        <div class="container">
            <h2 class="section-title">Selected Work</h2>
            <div class="grid portfolio-grid">
                <!-- Project 1 -->
                <div class="project-card glass" data-aos="fade-up">
                    <div class="project-img" style="background: linear-gradient(45deg, #1e293b, #3b82f6);"></div>
                    <div class="project-info">
                        <h3>FinTrack SaaS</h3>
                        <p>A financial analytics dashboard for small businesses.</p>
                        <span class="tech">React • Node.js • Chart.js</span>
                        <p class="result">Result: Reduced data processing time by 40%.</p>
                    </div>
                </div>
                <!-- Project 2 -->
                <div class="project-card glass" data-aos="fade-up" data-aos-delay="100">
                    <div class="project-img" style="background: linear-gradient(45deg, #1e293b, #06b6d4);"></div>
                    <div class="project-info">
                        <h3>SwiftStore E-com</h3>
                        <p>Minimalist fashion store with seamless checkout.</p>
                        <span class="tech">Next.js • Stripe • Tailwind</span>
                        <p class="result">Result: 25% increase in mobile conversions.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Pricing -->
    <section class="pricing" id="pricing">
        <div class="container">
            <h2 class="section-title">Clear Pricing</h2>
            <div class="grid pricing-grid">
                <div class="price-card glass" data-aos="flip-left">
                    <h4>Starter</h4>
                    <div class="price">$499<span>/project</span></div>
                    <ul>
                        <li>Single Page Landing Page</li>
                        <li>Mobile Responsive</li>
                        <li>Contact Form</li>
                        <li>5 Days Delivery</li>
                    </ul>
                    <a href="#contact" class="btn-outline">Choose Starter</a>
                </div>
                <div class="price-card glass featured" data-aos="flip-left" data-aos-delay="100">
                    <div class="popular">Most Popular</div>
                    <h4>Business</h4>
                    <div class="price">$1,200<span>/project</span></div>
                    <ul>
                        <li>Up to 5 Pages Website</li>
                        <li>SEO Optimization</li>
                        <li>CMS Integration</li>
                        <li>14 Days Delivery</li>
                    </ul>
                    <a href="#contact" class="btn-primary">Choose Business</a>
                </div>
                <div class="price-card glass" data-aos="flip-left" data-aos-delay="200">
                    <h4>Custom App</h4>
                    <div class="price">$2,500<span>+</span></div>
                    <ul>
                        <li>Full Web/Mobile App</li>
                        <li>Custom Backend</li>
                        <li>Database Integration</li>
                        <li>Priority Support</li>
                    </ul>
                    <a href="#contact" class="btn-outline">Let's Talk</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact -->
    <section class="contact" id="contact">
        <div class="container">
            <div class="contact-box glass">
                <div class="contact-info">
                    <h2>Ready to launch?</h2>
                    <p>Have a project in mind? Let's discuss how I can help your business grow.</p>
                    <div class="contact-links">
                        <a href="mailto:hello@davlaunch.com"><i data-lucide="mail"></i> hello@davlaunch.com</a>
                        <a href="https://wa.me/yournumber" class="whatsapp-link"><i data-lucide="message-circle"></i> Chat on WhatsApp</a>
                    </div>
                </div>
                <form class="contact-form">
                    <input type="text" placeholder="Your Name" required>
                    <input type="email" placeholder="Your Email" required>
                    <textarea placeholder="Tell me about your project" rows="5" required></textarea>
                    <button type="submit" class="btn-primary">Send Message</button>
                </form>
            </div>
        </div>
    </section>

    <footer>
        <div class="container">
            <p>&copy; 2024 Dav Launch Studio by Hardik Parmar. All rights reserved.</p>
        </div>
    </footer>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.js"></script>
    <script src="js/main.js"></script>
